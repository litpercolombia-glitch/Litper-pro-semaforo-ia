# ══════════════════════════════════════════════════════════════
# LITPERPRO — Variables de Entorno
# Copiar a .env.local para desarrollo local con Vercel CLI
# En producción, configurar en Vercel Dashboard > Settings > Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
# URL del proyecto Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key (pública, usada en frontend — protegida por RLS)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Service Role Key (SECRETA — solo backend, bypasses RLS)
# Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ── IA API Keys (backend only — NUNCA en frontend) ──────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-gemini-key-aqui

# Anthropic Console: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=tu-claude-key-aqui

# OpenAI Platform: https://platform.openai.com/api-keys
OPENAI_API_KEY=tu-openai-key-aqui
