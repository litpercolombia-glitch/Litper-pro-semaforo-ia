{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/$1" },
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/dashboard/?$", "dest": "/public/index.html" },
    { "src": "^/landing/?$", "dest": "/public/landing.html" },
    { "src": "^/checkout/?$", "dest": "/public/checkout.html" },
    { "src": "^/login/?$", "dest": "/public/login.html" },
    { "src": "^/pricing/?$", "dest": "/public/pricing.html" },
    { "src": "^/profile/?$", "dest": "/public/profile.html" },
    { "src": "^/(.*)", "dest": "/public/$1" }
  ]
}
